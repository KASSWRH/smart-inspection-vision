# ── Application ───────────────────────────────────────────
APP_NAME="Smart Inspection Vision System"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-32-char-random-string-in-production

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./inspection.db
# Production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/inspection

# ── Model ─────────────────────────────────────────────────
DETECTION_MODEL_PATH=models/detection/best.pt
DEFAULT_CONFIDENCE_THRESHOLD=0.45
DEFAULT_IOU_THRESHOLD=0.45
IMAGE_SIZE=640

# ── MLflow ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=smart-inspection

# ── Audit ─────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.jsonl
